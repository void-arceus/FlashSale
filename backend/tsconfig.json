{
    "compilerOptions": {
        "target": "ES2022", // Compile to modern JavaScript
        "module": "commonjs", // Standard Node.js module system
        "rootDir": "./src", // Where your TypeScript source code lives
        "outDir": "./dist", // Where the compiled JavaScript will go
        "esModuleInterop": true, // Enables standard import/export syntax
        "forceConsistentCasingInFileNames": true, // Protects against case-sensitive OS bugs
        "strict": true, // Turns on all strict type-checking rules
        "skipLibCheck": true // Speeds up compilation by skipping library checks
    },
    "include": ["src/**/*"] // Tells TS to only monitor files inside src/
}
